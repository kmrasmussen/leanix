{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/dottickets/statuses.schema.json",
  "title": "DotTickets Status Settings",
  "type": "object",
  "additionalProperties": false,
  "required": ["statuses"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "default_status": {
      "type": "string",
      "minLength": 1
    },
    "statuses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["key"],
        "properties": {
          "key": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
